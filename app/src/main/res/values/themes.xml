<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Aegis is always presented in its dark "vault" theme regardless of system setting. -->
    <style name="Base.Theme.ProjectAegis" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/aegis_gold</item>
        <item name="colorOnPrimary">@color/aegis_on_gold</item>
        <item name="colorPrimaryContainer">@color/aegis_gold_container</item>
        <item name="colorOnPrimaryContainer">@color/aegis_gold</item>

        <item name="colorSecondary">@color/aegis_teal</item>
        <item name="colorOnSecondary">@color/aegis_on_gold</item>

        <item name="android:colorBackground">@color/aegis_bg</item>
        <item name="colorSurface">@color/aegis_surface</item>
        <item name="colorOnSurface">@color/aegis_on_bg</item>
        <item name="colorOnBackground">@color/aegis_on_bg</item>
        <item name="colorSurfaceVariant">@color/aegis_surface_alt</item>
        <item name="colorOnSurfaceVariant">@color/aegis_on_bg_muted</item>

        <item name="colorOutline">@color/aegis_outline</item>
        <item name="colorError">@color/aegis_error</item>

        <item name="android:statusBarColor">@color/aegis_bg</item>
        <item name="android:navigationBarColor">@color/aegis_bg</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
        <item name="android:windowLightNavigationBar" tools:ignore="NewApi">false</item>
    </style>

    <style name="Theme.ProjectAegis" parent="Base.Theme.ProjectAegis" />

    <style name="Aegis.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/aegis_surface</item>
        <item name="cardCornerRadius">18dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/aegis_outline</item>
        <item name="strokeWidth">1dp</item>
        <item name="contentPadding">16dp</item>
    </style>

    <style name="Aegis.Button.Primary" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/aegis_gold</item>
        <item name="android:textColor">@color/aegis_on_gold</item>
        <item name="cornerRadius">14dp</item>
    </style>

    <style name="Aegis.Button.Text" parent="Widget.Material3.Button.TextButton">
        <item name="android:textColor">@color/aegis_teal</item>
    </style>

    <style name="Aegis.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/aegis_outline</item>
        <item name="hintTextColor">@color/aegis_on_bg_muted</item>
        <item name="android:textColorHint">@color/aegis_on_bg_muted</item>
        <item name="boxCornerRadiusTopStart">14dp</item>
        <item name="boxCornerRadiusTopEnd">14dp</item>
        <item name="boxCornerRadiusBottomStart">14dp</item>
        <item name="boxCornerRadiusBottomEnd">14dp</item>
    </style>

    <style name="Aegis.Toolbar" parent="Widget.Material3.Toolbar">
        <item name="android:background">@color/aegis_bg</item>
        <item name="titleTextColor">@color/aegis_on_bg</item>
    </style>
</resources>
