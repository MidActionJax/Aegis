<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/aegis_bg"
    android:fitsSystemWindows="true"
    android:orientation="vertical"
    tools:context=".CredentialDetailActivity">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/aegis_bg"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:titleTextColor="@color/aegis_on_bg" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/detailAccountName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/aegis_on_bg"
            android:textSize="24sp"
            android:textStyle="bold"
            tools:text="GitHub" />

        <TextView
            android:id="@+id/detailUrl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/aegis_teal"
            android:textSize="13sp"
            tools:text="https://github.com" />

        <com.google.android.material.card.MaterialCardView
            style="@style/Aegis.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/label_username"
                    android:textColor="@color/aegis_on_bg_muted"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/detailUsername"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="20dp"
                    android:textColor="@color/aegis_on_bg"
                    android:textSize="16sp"
                    tools:text="jaxon@example.com" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/label_password"
                    android:textColor="@color/aegis_on_bg_muted"
                    android:textSize="12sp" />

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp">

                    <TextView
                        android:id="@+id/detailPassword"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:fontFamily="monospace"
                        android:textColor="@color/aegis_on_bg"
                        android:textSize="18sp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/detailToggleVisibility"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        tools:text="••••••••••" />

                    <ImageButton
                        android:id="@+id/detailToggleVisibility"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="@string/action_toggle_visibility"
                        android:src="@drawable/ic_visibility"
                        app:layout_constraintEnd_toStartOf="@id/detailCopyButton"
                        app:layout_constraintTop_toTopOf="parent" />

                    <ImageButton
                        android:id="@+id/detailCopyButton"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="@string/action_copy_password"
                        android:src="@drawable/ic_copy"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</LinearLayout>
